{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "types": ["jest", "react-native-vector-icons"],
    "baseUrl": "./src",
    "paths": {
      "@app/*": ["app/*"],
      "@navigation/*": ["navigation/*"],
      "@screens/*": ["screens/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@store/*": ["store/*"],
      "@services/*": ["services/*"],
      "@types/*": ["types/*"],
      "@constants/*": ["constants/*"],
      "@utils/*": ["utils/*"],
      "@assets/*": ["assets/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
